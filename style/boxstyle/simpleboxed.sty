\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{boxstyle/simpleboxed}[2025/05/10 simpleboxed style]


\tcbset{
    % 黒枠で囲む
    simpleboxed/.style = {
        enhanced,% tikz系のコマンドに必要
        attach boxed title to top left = {% タイトルボックスの位置
            xshift=3mm, yshift=-3mm
        },%
        colback = black!5!white,% 背景の色
        colframe = black,% 枠の色
        top = 4mm,% 枠と内側の本文との間隔
        boxrule = 1pt,% ← 枠の太さ
        coltitle = black,% タイトルの文字の色        
        boxed title style = {%ボックスの中の設定
            colframe = black,%
            colback = black!5!white%
        }%
    }
}