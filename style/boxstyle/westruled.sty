\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{boxstyle/westruled}[2025/05/10 westruled style]


\tcbset{
    % 左側に線を引く
    westruled/.style = {
        enhanced,% tikz系のコマンドに必要(overlay)
        detach title,% タイトルボックスを削除
        frame hidden,% 枠線を消去
        boxrule=0pt,
        sharp corners,% 角を直角
        colback = white,
        coltitle = black,
        before skip = 5pt,  % ← 上の余白
        after skip = 5pt,   % ← 下の余白
        overlay = {
            \draw[\tcbcol@overlay, line width=2pt]
            ([xshift=0mm]interior.south west) -- ([xshift=0mm]interior.north west); 
        },
        line color/.store in=\tcbcol@overlay,
        line color=gray,% default
    }
}