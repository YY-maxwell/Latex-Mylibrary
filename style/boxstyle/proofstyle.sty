\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{boxstyle/proofstyle}[2025/05/10 westruled style]
\newdimen\proofbox@linelength

\tcbset{
    proofstyle/.style = {
        enhanced,% tikz系のコマンドに必要(overlay)
        detach title,% タイトルボックスを削除,
        breakable,
        frame hidden,% 枠線を消去
        sharp corners,% 角を直角
        colback = white,
        coltitle = black,
        before skip = 0pt,  % ← 上の余白
        after skip = 5pt,   % ← 下の余白
        overlay unbroken={% ページまたぎがない場合
            \path let \p1 = ([xshift=0.5pt,yshift=-23pt]frame.north west),
                    \p2 = ([xshift=0.5pt,yshift= 7pt]frame.south west) in%
                    %\n1 = {\y1-\y2} in
            \pgfextra{%
                \proofbox@linelength=\dimexpr\y1-\y2\relax
                \typeout{proofbox line length = \the\proofbox@linelength}%
                \ifdim\y1>\y2\relax
                    \ifdim\proofbox@linelength>15pt\relax
                        \draw[\tcbcol@overlay, line width=0.5pt]
                        ([xshift=0.5pt,yshift=-23pt]frame.north west) --
                        ([xshift=0.5pt,yshift= 7pt]frame.south west);
                    \fi
                \fi
            };%
        },
        overlay first={% ページをまたぐ時の最初のページ
            \path let \p1 = ([xshift=0.5pt,yshift=-23pt]frame.north west),
            \p2 = ([xshift=0.5pt]frame.south west) in
            \pgfextra{%
                \ifdim\y1>\y2\relax
                    \draw[\tcbcol@overlay, line width=0.5pt]
                    ([xshift=0.5pt,yshift=-23pt]frame.north west) --
                    ([xshift=0.5pt]frame.south west);
                \fi
            };
        },
        overlay middle={% 2ページ目から最終ページの一つ前まで
            \path let \p1 = ([xshift=0.5pt]frame.north west),
                    \p2 = ([xshift=0.5pt]frame.south west) in
            \pgfextra{%
                \ifdim\y1>\y2\relax
                \draw[\tcbcol@overlay, line width=0.5pt]
                    ([xshift=0.5pt]frame.north west) --
                    ([xshift=0.5pt]frame.south west);
                \fi
            };
        },
        overlay last={% 最終ページ
            \path let \p1 = ([xshift=0.5pt]frame.north west),
                    \p2 = ([xshift=0.5pt,yshift=6pt]frame.south west) in
            \pgfextra{%
                \ifdim\y1>\y2\relax
                \draw[\tcbcol@overlay, line width=0.5pt]
                    ([xshift=0.5pt]frame.north west) --
                    ([xshift=0.5pt,yshift=7pt]frame.south west);
                \fi
            };
        },
        line color/.store in=\tcbcol@overlay,
        line color=gray,% default
    }
}

% --- proofbox --- %
\newtcolorbox{proofbox}[1][\textbf{Proof.}]{
    proofstyle,
    line color = gray,
    title = {#1},
    before upper={
        \hspace*{-15pt}\tcbtitle\;
    }
}