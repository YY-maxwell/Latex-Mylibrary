\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{base-packages}[2025/09/17 load fundamental packages and settings]


% --- math related packages ---
\RequirePackage{mathtools}% enhanced math environments
\RequirePackage{amssymb}% 
\RequirePackage{xfrac}% better fractions


% --- tikz related packages ---
\RequirePackage{tikz, tikz-cd}% drawing figures and commutative diagrams
\usetikzlibrary{calc}% use tikz calculation library


% --- graphics ---
\RequirePackage{graphicx}%


% --- advanced commenting ---
\RequirePackage{comment}


% --- colors ---
\RequirePackage{xcolor}%


% --- boxed environments ---
\RequirePackage[most]{tcolorbox}%


% --- advanced lists ---
\RequirePackage{enumitem}%


% --- fonts ---
\RequirePackage{fontspec}% system font selection (Latin scripts)
\RequirePackage{unicode-math}% Unicode math fonts
\setmathfont{New Computer Modern Math}% set default font for math 
\setmathfont[range=\mathcal]{Euler Math}% for calligraphic letters