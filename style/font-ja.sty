\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{font-ja}[2025/09/17 default font settings for jlreq]


\RequirePackage{luatexja}% Japanese typesetting support
\RequirePackage{luatexja-fontspec}% Japanese font selection via fontspec


% --- 見出しのフォント設定 ---
\RequirePackage{titlesec}%


\titleformat{\section}% セクションタイトル
    {\LARGE\gtfamily\sffamily}% フォント
    {\thesection}% ラベル
    {1em}% ラベルとタイトルの間隔
    {}% 後続の修飾
\titlespacing*{\section}%
    {0pt}% 左の余白
    {20pt}% タイトルの前（上）の余白
    {10pt}% タイトルの後（下）の余白 ← これがセクション直後の段落までのスペース


\titleformat{\subsection}% サブセクションタイトル
    {\Large\gtfamily\sffamily}% フォント
    {\thesubsection}% ラベル
    {1em}% ラベルとタイトルの間隔
    {}% 後続の修飾


\titleformat{\subsubsection}% サブサブセクションタイトル
    {\large\gtfamily\sffamily}% フォント
    {\thesubsubsection}% ラベル
    {1em}% ラベルとタイトルの間隔
    {}% ラベルとタイトルの間隔
\titlespacing*{\subsubsection}%
    {0pt}
    {10pt}
    {5pt}